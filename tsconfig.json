{
	"compilerOptions": {
		"module": "nodenext",
		"target": "es2015",
		"moduleResolution": "nodenext",
		"noImplicitAny": false,
		"sourceMap": true,
		"declaration": true,
		"strict": true,
		"rootDir": "src/",
		"outDir": "dist/",
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}